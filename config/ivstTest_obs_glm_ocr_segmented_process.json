{
  "layout": "./config/ivstTest_template_roi_layout.glm_ocr.json",
  "ocr_output_dir": "./ivstTest/ocr",
  "code_output_dir": "./ivstTest/code",
  "capture_dir": "./ivstTest/captures",
  "runtime_log_file": "./ivstTest/logs/run_process_existing.runtime.log",
  "skip_capture": true,
  "emit_partial": true,
  "session_name": "ivstTest_obs_glm_roi_segmented",
  "glm_model_path": "./external_models/GLM-OCR",
  "glm_device": "directml",
  "glm_target": "all",
  "glm_line_mode": "segmented",
  "glm_max_new_tokens": 512,
  "glm_full_max_edge": 0,
  "glm_local_files_only": true,
  "directml_rebuild_pages": 5,
  "short_page_cpu_threshold": 4,
  "directml_restart_gpu_shared_gib": 18.0,
  "directml_restart_private_gib": 21.0,
  "directml_resume_gpu_shared_gib": 12.0,
  "directml_resume_private_gib": 16.0,
  "directml_cpu_cooldown_pages": 3
